{
    "rules": {
        "saran": {
            /* Hanya user yang sudah login (Authenticated) yang bisa membaca semua saran */
            ".read": "auth != null",
            /* Hanya user yang sudah login yang bisa mengirim (menambah) saran baru */
            ".write": "auth != null",
            "$saran_id": {
                /* Validasi: Pastikan data yang masuk memiliki field yang lengkap */
                ".validate": "newData.hasChildren(['nama', 'pesan', 'created_at'])",
                "pesan": {
                    /* Validasi: Pesan tidak boleh kosong dan harus berupa string */
                    ".validate": "newData.isString() && newData.val().length > 0"
                }
            }
        },
        "test": {
            /* Path testing dikunci total agar aman */
            ".read": false,
            ".write": false
        },
        "wedding": {
            /* Path bawaan sebelumnya dikunci sementara */
            ".read": false,
            ".write": false
        }
    }
}